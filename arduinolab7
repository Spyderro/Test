#include <Wire.h>
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2); // Adres zazwyczaj 0x27 lub 0x3F

const int trigPin = 6;
const int echoPin = 7;
const int buttonPin = 8;

void setup() {
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  pinMode(buttonPin, INPUT_PULLUP); // Przycisk do GND
  
  lcd.init();
  lcd.backlight();
}

void loop() {
  if (digitalRead(buttonPin) == LOW) { // Reakcja na wciśnięcie
    digitalWrite(trigPin, LOW);
    delayMicroseconds(2);
    digitalWrite(trigPin, HIGH);
    delayMicroseconds(10);
    digitalWrite(trigPin, LOW);

    long czas = pulseIn(echoPin, HIGH);
    int dystans = czas * 0.034 / 2;

    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Dystans: ");
    lcd.print(dystans);
    lcd.print(" cm");
    
    delay(500); // Odczekanie żeby nie "migało" przy trzymaniu
  }
}

