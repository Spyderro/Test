void loop() {
  long suma = 0;

  for(int i = 0; i < 3; i++) {
    digitalWrite(trigPin, LOW);
    delayMicroseconds(2);
    digitalWrite(trigPin, HIGH);
    delayMicroseconds(10);
    digitalWrite(trigPin, LOW);
    
    long czas = pulseIn(echoPin, HIGH);
    suma += (czas * 0.034 / 2);
    delay(50); // Krótki odstęp między odczytami
  }

  int srednia = suma / 3;

  lcd.clear();
  lcd.print("Srednia z 3:");
  lcd.setCursor(0, 1);
  lcd.print(srednia);
  lcd.print(" cm");
  
  delay(1000); // Opóźnienie przed kolejną serią
}

